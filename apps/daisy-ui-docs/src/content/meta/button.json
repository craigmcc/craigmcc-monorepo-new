{
  "component": "Button",
  "package": "@repo/daisy-ui",
  "description": "A button in various styles.",
  "props": [
    {
      "name": "active",
      "type": "\"false\" | \"true\"",
      "required": false,
      "default": "false",
      "description": "Present with active styling",
      "enumValues": [
        "false",
        "true"
      ]
    },
    {
      "name": "block",
      "type": "\"false\" | \"true\"",
      "required": false,
      "default": "false",
      "description": "Make this component full width",
      "enumValues": [
        "false",
        "true"
      ]
    },
    {
      "name": "circle",
      "type": "\"false\" | \"true\"",
      "required": false,
      "default": "false",
      "description": "Present with a 1:1 ratio with rounded corners",
      "enumValues": [
        "false",
        "true"
      ]
    },
    {
      "name": "color",
      "type": "\"accent\" | \"error\" | \"ghost\" | \"info\" | \"neutral\" | \"primary\" | \"secondary\" | \"success\" | \"warning\"",
      "required": false,
      "default": "primary",
      "description": "Base color for this component",
      "enumValues": [
        "accent",
        "error",
        "ghost",
        "info",
        "neutral",
        "primary",
        "secondary",
        "success",
        "warning"
      ]
    },
    {
      "name": "dash",
      "type": "\"false\" | \"true\"",
      "required": false,
      "default": "false",
      "description": "Present with dashed border instead of background color",
      "enumValues": [
        "false",
        "true"
      ]
    },
    {
      "name": "disabled",
      "type": "\"false\" | \"true\"",
      "required": false,
      "default": "false",
      "description": "Present with disabled styling (can also use \"disabled\" attribute on a <button>)",
      "enumValues": [
        "false",
        "true"
      ]
    },
    {
      "name": "outline",
      "type": "\"false\" | \"true\"",
      "required": false,
      "default": "false",
      "description": "Present with solid outline border instead of background color",
      "enumValues": [
        "false",
        "true"
      ]
    },
    {
      "name": "size",
      "type": "\"lg\" | \"md\" | \"sm\" | \"xl\" | \"xs\"",
      "required": false,
      "default": "md",
      "description": "Basic size of this component",
      "enumValues": [
        "lg",
        "md",
        "sm",
        "xl",
        "xs"
      ]
    },
    {
      "name": "soft",
      "type": "\"false\" | \"true\"",
      "required": false,
      "default": "false",
      "description": "Soften the color presentation if true",
      "enumValues": [
        "false",
        "true"
      ]
    },
    {
      "name": "square",
      "type": "\"false\" | \"true\"",
      "required": false,
      "default": "false",
      "description": "Present with a 1:1 ratio",
      "enumValues": [
        "false",
        "true"
      ]
    }
  ],
  "examples": []
}
