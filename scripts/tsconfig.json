{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "types": ["node"],
    "paths": {
      "@repo/*": ["../packages/*/src", "../apps/*/src"]
    }
  },
  "include": ["*.ts"],
  "exclude": ["node_modules", "../node_modules"]
}

