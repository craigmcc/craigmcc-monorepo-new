{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@repo/*": ["./packages/*/src", "./apps/*/src"]
    }
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}



